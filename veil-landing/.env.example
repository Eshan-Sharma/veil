# ─── Cluster selector ────────────────────────────────────────────────────────
# Pins the build to a single Solana cluster. Cluster-scoped tables carry a
# `cluster` column, so one Neon DB can hold rows for multiple clusters in dev.
# Set this per Vercel environment (Production = mainnet, Preview = devnet).
NEXT_PUBLIC_SOLANA_CLUSTER=devnet

# ─── Public app configuration ────────────────────────────────────────────────
NEXT_PUBLIC_VEIL_PROGRAM_ID=<deployed-program-id-for-this-cluster>
NEXT_PUBLIC_SOL_MINT=So11111111111111111111111111111111111111112
NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
NEXT_PUBLIC_DOCS_URL=http://localhost:3001

# ─── Database ────────────────────────────────────────────────────────────────
# A single DB is enough since rows are scoped by `cluster`. For production,
# point this at a dedicated mainnet Neon project so user data is isolated from
# dev clusters.
DATABASE_URL=postgres://user:password@host:5432/veil

# ─── Bootstrap super admin ───────────────────────────────────────────────────
SUPER_ADMIN_PUBKEY=<admin-wallet-pubkey>

# ─── Server-side RPC overrides (optional) ────────────────────────────────────
MAINNET_RPC=https://api.mainnet-beta.solana.com
DEVNET_RPC=https://api.devnet.solana.com
LOCALNET_RPC=http://127.0.0.1:8899

# ─── Other server-side settings ──────────────────────────────────────────────
PUBLIC_ORIGIN=http://localhost:3000

# ─── Optional script overrides ───────────────────────────────────────────────
INDEXER_RPC=
KEEPER_RPC=
KEEPER_API_BASE=http://localhost:4321
KEEPER_INTERVAL_SEC=30
KEEPER_KEYPAIR=[1,2,3]

# ─── Localnet/devnet setup keypair ───────────────────────────────────────────
# Path to the JSON-array keypair the setup scripts should use as the payer
# (must match MOCK_ADMIN baked into the on-chain program).
PAYER_KEYPAIR=

# ─── Frontend e2e test wallets ───────────────────────────────────────────────
# Set NEXT_PUBLIC_TEST_WALLET=1 to register the TestWalletAdapter in the dapp.
# Never enable on mainnet — the provider also refuses to load it there.
NEXT_PUBLIC_TEST_WALLET=0
# Paths to JSON-array keypair files used by frontend-e2e-tests. Generate with
# `solana-keygen new --outfile <path>`.
TEST_ADMIN_KEYPAIR=
TEST_USER_KEYPAIR=/tmp/test-user.json
TEST_VICTIM_KEYPAIR=/tmp/test-victim.json
